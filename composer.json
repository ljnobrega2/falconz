{
    "require": {
        "setasign/fpdi": "^2.6",
        "setasign/fpdf": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "classmap": [
            "tests/bootstrap/"
        ]
    },
    "scripts": {
        "test":          "phpunit",
        "test-financial":"phpunit --testsuite Financial",
        "test-webhook":  "phpunit --testsuite Webhook",
        "test-coverage": "phpunit --coverage-text"
    },
    "config": {
        "allow-plugins": {}
    }
}
