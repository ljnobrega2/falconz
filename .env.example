# Senderzz Standalone — Environment Variables
# Copy to .env and fill values. Never commit .env to git.

DB_HOST=localhost
DB_NAME=senderzz_db
DB_USER=senderzz_user
DB_PASSWORD=your_strong_password_here
DB_PREFIX=wp_

AUTH_KEY=put-your-unique-phrase-here
AUTH_SALT=put-your-unique-phrase-here

SZ_HOME_URL=https://app.senderzz.com
SZ_REST_URL=https://app.senderzz.com/wp-json
SZ_TIMEZONE=America/Sao_Paulo
SZ_LOCALE=pt_BR
SZ_SITE_NAME=Senderzz

SZ_UPLOAD_DIR=/var/www/senderzz/storage/uploads
SZ_UPLOAD_URL=https://app.senderzz.com/storage/uploads

TPC_WEBHOOK_SECRET=your_webhook_secret
TPC_JWT_SECRET=your_jwt_secret
ME_TOKEN=your_melhor_envio_token
